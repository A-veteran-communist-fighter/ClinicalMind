# ==========================================
# ClinicalMind - Environment Configuration
# ==========================================
# Copy to .env and fill in ONE LLM API Key:
#   cp .env.example .env
# ==========================================

# ═══════════════════════════════════════════
# LLM Provider (REQUIRED — pick one)
# ═══════════════════════════════════════════

# --- DeepSeek (recommended) ---
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# --- OpenAI ---
OPENAI_API_KEY=sk-your-openai-key
OPENAI_BASE_URL=https://api.openai.com/v1

# --- GLM / Zhipu ---
GLM_API_KEY=your-glm-key
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# --- Moonshot / Kimi ---
MOONSHOT_API_KEY=sk-your-moonshot-key
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1

# --- Alibaba / Qwen (DashScope) ---
DASHSCOPE_API_KEY=sk-your-dashscope-key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Model name (default: deepseek-chat)
DEFAULT_LLM_MODEL=deepseek-chat


# ═══════════════════════════════════════════
# Vision Model (optional — for lab report parsing)
# ═══════════════════════════════════════════
# If not set, the 'lab' command is disabled gracefully.
# The vision model is independent of the main LLM above.

# VISION_API_KEY=sk-your-openai-key
# VISION_BASE_URL=https://api.openai.com/v1
# VISION_MODEL=gpt-4o
